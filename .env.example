# AI intent extraction (optional; deterministic showcase parser is the safe fallback)
GOOGLE_GENERATIVE_AI_API_KEY=

# Durable Neon/Postgres storage. Without this, local development uses volatile memory.
DATABASE_URL=

# Hedera testnet treasury. Never use a mainnet key in this demo.
HEDERA_OPERATOR_ID=0.0.0000000
HEDERA_OPERATOR_PRIVATE_KEY=
HEDERA_VENDOR_ACCOUNT_ID=0.0.0000000
HEDERA_HCS_TOPIC_ID=0.0.0000000

# GitHub API token for authenticated security evidence collection.
GITHUB_TOKEN=

# 32+ random bytes used to hash public-demo session and IP identifiers.
SESSION_SECRET=

# Public URL, used for origin validation and metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000
